{
  "version": 1,
  "kind": "agent",
  "name": "character_identity_resolver",
  "package": "prompt_generation/character_identity_resolver",
  "display_name": "角色身份解析",
  "config": {
    "prompt": "解析 SceneDocument 中明确命名角色的规范英文或罗马字名称、作品来源和真实 Danbooru 角色标签候选。不得用相似角色替代，不确定时保留名称并留空标签。",
    "model": "deepseek-v4-pro",
    "temperature": 0.1
  },
  "state": {
    "identity_context": { "type": "dict", "optional": true },
    "previous_resolved_prompt_ir": { "type": "dict", "optional": true },
    "impact_set": { "type": "dict", "optional": true },
    "identity_terms": { "type": "list", "optional": true },
    "identity_tag_records": { "type": "list", "optional": true },
    "identity_tag_resolutions": { "type": "list", "optional": true },
    "identity_tag_adjudication": { "type": "dict", "optional": true },
    "identity_search_terms": { "type": "list", "optional": true },
    "prepared_context": { "type": "dict", "optional": true }
  },
  "entrypoint": "prepare_context",
  "nodes": {
    "prepare_context": { "handler": "prepare_context_node" },
    "collect_identities": { "handler": "collect_identities_node" },
    "resolve_identities": { "handler": "resolve_identities_node" },
    "validate_identity_result": { "handler": "validate_identity_result_node" }
  },
  "edges": [
    { "from": "prepare_context", "to": "collect_identities" },
    { "from": "collect_identities", "to": "resolve_identities" },
    { "from": "resolve_identities", "to": "validate_identity_result" },
    { "from": "validate_identity_result", "to": "END" }
  ]
}
