{
  "version": 1,
  "kind": "agent",
  "name": "prompt_impact_router",
  "package": "prompt_generation/prompt_impact_router",
  "display_name": "影响范围路由",
  "config": {
    "prompt": "根据 ImpactSet 确定本轮需要重新执行的解析范围。",
    "temperature": 0
  },
  "state": {
    "impact_set": { "type": "dict", "optional": true },
    "should_resolve_identity": { "type": "boolean", "optional": true },
    "should_resolve_visual": { "type": "boolean", "optional": true }
  },
  "entrypoint": "route_impact",
  "nodes": {
    "route_impact": { "handler": "route_impact_node" }
  },
  "edges": [{ "from": "route_impact", "to": "END" }]
}
