{
  "version": 1,
  "kind": "agent",
  "name": "scene_document_editor",
  "package": "prompt_generation/scene_document_editor",
  "display_name": "画面状态编辑器",
  "config": {
    "prompt": "把用户最新自然语言修改转换为对 SceneDocument 的受限 JSON Patch。完整保留未被修改的画面事实，正确处理补充、删除、替换、恢复、强调、指代和对上次结果的缺陷反馈。",
    "model": "deepseek-v4-pro",
    "temperature": 0.1
  },
  "state": {
    "scene_document": { "type": "dict", "optional": true },
    "previous_scene_document": { "type": "dict", "optional": true },
    "previous_resolved_prompt_ir": { "type": "dict", "optional": true },
    "patch_proposal": { "type": "dict", "optional": true },
    "clarification_request": { "type": "string", "optional": true },
    "editor_error": { "type": "string", "optional": true }
  },
  "entrypoint": "propose_patch",
  "nodes": {
    "propose_patch": { "handler": "propose_patch_node" }
  },
  "edges": [{ "from": "propose_patch", "to": "END" }]
}
