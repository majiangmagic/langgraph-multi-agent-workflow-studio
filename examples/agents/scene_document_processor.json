{
  "version": 1,
  "kind": "agent",
  "name": "scene_document_processor",
  "package": "prompt_generation/scene_document_processor",
  "display_name": "画面工程更新",
  "config": {
    "prompt": "确定性校验并执行 SceneDocument Patch，计算本轮影响范围。",
    "temperature": 0
  },
  "state": {
    "scene_document": { "type": "dict", "optional": true },
    "previous_scene_document": { "type": "dict", "optional": true },
    "previous_resolved_prompt_ir": { "type": "dict", "optional": true },
    "patch_proposal": { "type": "dict", "optional": true },
    "impact_set": { "type": "dict", "optional": true },
    "identity_context": { "type": "dict", "optional": true },
    "visual_context": { "type": "dict", "optional": true },
    "patch_error": { "type": "string", "optional": true }
    ,"clarification_request": { "type": "string", "optional": true }
    ,"clarification_options": { "type": "list", "optional": true }
    ,"document_valid": { "type": "boolean", "optional": true }
    ,"prepared_context": { "type": "dict", "optional": true }
  },
  "entrypoint": "prepare_context",
  "nodes": {
    "prepare_context": { "handler": "prepare_context_node" },
    "validate_patch": { "handler": "validate_patch_node" },
    "apply_patch": { "handler": "apply_patch_node" },
    "validate_document": { "handler": "validate_document_node" },
    "build_agent_contexts": { "handler": "build_agent_contexts_node" }
  },
  "edges": [
    { "from": "prepare_context", "to": "validate_patch" },
    { "from": "validate_patch", "to": "apply_patch" },
    { "from": "apply_patch", "to": "validate_document" },
    { "from": "validate_document", "to": "build_agent_contexts" },
    { "from": "build_agent_contexts", "to": "END" }
  ]
}
