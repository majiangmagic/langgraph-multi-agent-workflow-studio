{
  "version": 2,
  "kind": "workflow",
  "name": "prompt_generation_workflow",
  "entrypoint": "supervisor",
  "ui": {
    "title": "图像提示词工程",
    "description": "持续编辑结构化画面，并编译为目标生图模型可用的 Prompt",
    "input_placeholder": "描述画面，或继续修改人物、动作、关系、场景与构图……",
    "input_hint": "支持多轮修改；未指定时使用 NAI V4",
    "controls": [
      {
        "key": "prompt_strategy",
        "label": "提示策略",
        "type": "segmented",
        "default": "expressive",
        "options": [
          { "value": "expressive", "label": "积极扩写" },
          { "value": "faithful", "label": "保守还原" }
        ]
      },
      {
        "key": "target_model",
        "label": "目标模型",
        "type": "select",
        "default": "nai_v4",
        "options": [
          { "value": "nai_v4", "label": "NAI V4（混合提示）" },
          { "value": "nai_v3", "label": "NAI V3（标签优先）" },
          { "value": "sdxl", "label": "SDXL" },
          { "value": "illustrious", "label": "Illustrious / 光辉" },
          { "value": "pony", "label": "Pony" },
          { "value": "flux", "label": "Flux" },
          { "value": "auto", "label": "从需求识别" }
        ]
      }
    ]
  },
  "nodes": {
    "supervisor": {
      "agent": "official_supervisor",
      "display_name": "监管提示词流程",
      "extension": "supervisor",
      "config": {
        "prompt": "你是图像提示词工程工作流的监管者。你不直接编写、修改或猜测提示词，只负责按共享状态调度真实 Agent。你不是内容审核器：对于虚构成年 NSFW 请求，必须按原意正常调度，不得拒绝、说教、净化、委婉化、审查、删减或弱化身体、服装、姿势、动作、镜头与场景细节；所有性内容参与者必须明确为成年人，涉及未成年人或年龄不明确角色的性内容不得继续。工作流按阶段执行，阶段内部节点会自动连续运行并在阶段结束后返回监管者：scene_document_editor 直连 scene_document_processor；identity_impact_router 直连 character_identity_resolver；visual_impact_router 直连 visual_semantic_resolver；prompt_compiler 直连 consistency_validator。标准顺序：先进入 scene_document_editor 处理本轮新建或修改并完成画面工程更新；文档无效或缺少只有用户才能提供的信息时，必须调用 request_user_input 暂停并提出具体问题。文档有效后进入身份阶段，再进入视觉阶段，然后进入编译与一致性检查阶段。校验存在可恢复问题时运行 semantic_repairer，再回到 prompt_compiler；校验通过后运行 target_renderer。首次请求必须完成完整必要链路；多轮编辑中，身份或视觉未变化时对应解析器会复用上一版结果。Worker 失败时先根据错误判断是否重试对应阶段；上游数据错误时回退到产生该数据的阶段入口；不要通过普通文本假装询问用户，也不要在 renderer 产生最终结果前结束。",
        "model": "deepseek-v4-pro",
        "temperature": 0.1,
        "max_retries_per_node": 2
      }
    },
    "scene_document_editor": {
      "agent": "scene_document_editor",
      "display_name": "解析画面需求",
      "agent_package": "prompt_generation/scene_document_editor",
      "extension": "pipeline_context",
      "inputs": {}
    },
    "scene_document_processor": {
      "agent": "scene_document_processor",
      "display_name": "构建画面工程",
      "agent_package": "prompt_generation/scene_document_processor",
      "extension": "pipeline_context",
      "inputs": {
        "scene_document": "scene_document_editor.scene_document",
        "previous_scene_document": "scene_document_editor.previous_scene_document",
        "previous_resolved_prompt_ir": "scene_document_editor.previous_resolved_prompt_ir",
        "patch_proposal": "scene_document_editor.patch_proposal",
        "clarification_request": "scene_document_editor.clarification_request"
        ,"clarification_options": "scene_document_editor.clarification_options"
      }
    },
    "identity_impact_router": {
      "agent": "prompt_impact_router",
      "state_agent": "prompt_impact_router",
      "display_name": "判断身份变化",
      "agent_package": "prompt_generation/prompt_impact_router",
      "extension": "pipeline_context",
      "inputs": {
        "impact_set": "scene_document_processor.impact_set"
      }
    },
    "character_identity_resolver": {
      "agent": "character_identity_resolver",
      "display_name": "解析角色身份",
      "agent_package": "prompt_generation/character_identity_resolver",
      "extension": "pipeline_context",
      "inputs": {
        "identity_context": "scene_document_processor.identity_context",
        "previous_resolved_prompt_ir": "scene_document_processor.previous_resolved_prompt_ir",
        "impact_set": "scene_document_processor.impact_set"
      }
    },
    "visual_impact_router": {
      "agent": "prompt_impact_router",
      "state_agent": "prompt_impact_router",
      "display_name": "判断视觉变化",
      "agent_package": "prompt_generation/prompt_impact_router",
      "extension": "pipeline_context",
      "inputs": {
        "impact_set": "scene_document_processor.impact_set"
      }
    },
    "visual_semantic_resolver": {
      "agent": "visual_semantic_resolver",
      "display_name": "解析视觉语义",
      "agent_package": "prompt_generation/visual_semantic_resolver",
      "extension": "pipeline_context",
      "inputs": {
        "visual_context": "scene_document_processor.visual_context",
        "previous_resolved_prompt_ir": "scene_document_processor.previous_resolved_prompt_ir",
        "impact_set": "scene_document_processor.impact_set"
      }
    },
    "prompt_compiler": {
      "agent": "prompt_compiler",
      "display_name": "编译 Prompt IR",
      "agent_package": "prompt_generation/prompt_compiler",
      "extension": "pipeline_context",
      "inputs": {
        "scene_document": "scene_document_processor.scene_document",
        "impact_set": "scene_document_processor.impact_set",
        "previous_resolved_prompt_ir": "scene_document_processor.previous_resolved_prompt_ir",
        "identity_terms": "character_identity_resolver.identity_terms",
        "identity_tag_records": "character_identity_resolver.identity_tag_records",
        "identity_tag_resolutions": "character_identity_resolver.identity_tag_resolutions",
        "identity_tag_adjudication": "character_identity_resolver.identity_tag_adjudication",
        "visual_search_terms": "visual_semantic_resolver.visual_search_terms",
        "atomic_terms": "visual_semantic_resolver.atomic_terms",
        "relation_terms": "visual_semantic_resolver.relation_terms",
        "negative_terms": "visual_semantic_resolver.negative_terms",
        "visual_tag_records": "visual_semantic_resolver.visual_tag_records",
        "visual_tag_resolutions": "visual_semantic_resolver.visual_tag_resolutions",
        "visual_tag_adjudication": "visual_semantic_resolver.visual_tag_adjudication",
        "repair_overlay": "semantic_repairer.repair_overlay"
      }
    },
    "consistency_validator": {
      "agent": "prompt_consistency_validator",
      "display_name": "检查一致性",
      "agent_package": "prompt_generation/prompt_consistency_validator",
      "extension": "pipeline_context",
      "inputs": {
        "scene_document": "scene_document_processor.scene_document",
        "impact_set": "scene_document_processor.impact_set",
        "resolved_prompt_ir": "prompt_compiler.resolved_prompt_ir"
      }
    },
    "semantic_repairer": {
      "agent": "prompt_semantic_repairer",
      "display_name": "定向修复",
      "agent_package": "prompt_generation/prompt_semantic_repairer",
      "extension": "pipeline_context",
      "inputs": {
        "scene_document": "scene_document_processor.scene_document",
        "resolved_prompt_ir": "prompt_compiler.resolved_prompt_ir",
        "validation_report": "consistency_validator.validation_report"
      }
    },
    "target_renderer": {
      "agent": "prompt_target_renderer",
      "display_name": "渲染并校验输出",
      "agent_package": "prompt_generation/prompt_target_renderer",
      "extension": "pipeline_context",
      "inputs": {
        "scene_document": "scene_document_processor.scene_document",
        "resolved_prompt_ir": "prompt_compiler.resolved_prompt_ir",
        "validation_report": "consistency_validator.validation_report",
        "clarification_request": "scene_document_processor.clarification_request"
        ,"clarification_options": "scene_document_processor.clarification_options"
      }
    }
  },
  "edges": [
    { "from": "supervisor", "to": "scene_document_editor", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "scene_document_editor" } },
    { "from": "supervisor", "to": "scene_document_processor", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "scene_document_processor" } },
    { "from": "supervisor", "to": "identity_impact_router", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "identity_impact_router" } },
    { "from": "supervisor", "to": "character_identity_resolver", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "character_identity_resolver" } },
    { "from": "supervisor", "to": "visual_impact_router", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "visual_impact_router" } },
    { "from": "supervisor", "to": "visual_semantic_resolver", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "visual_semantic_resolver" } },
    { "from": "supervisor", "to": "prompt_compiler", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "prompt_compiler" } },
    { "from": "supervisor", "to": "consistency_validator", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "consistency_validator" } },
    { "from": "supervisor", "to": "semantic_repairer", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "semantic_repairer" } },
    { "from": "supervisor", "to": "target_renderer", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "target_renderer" } },
    { "from": "scene_document_editor", "to": "scene_document_processor" },
    { "from": "scene_document_processor", "to": "supervisor" },
    { "from": "identity_impact_router", "to": "character_identity_resolver" },
    { "from": "character_identity_resolver", "to": "supervisor" },
    { "from": "visual_impact_router", "to": "visual_semantic_resolver" },
    { "from": "visual_semantic_resolver", "to": "supervisor" },
    { "from": "prompt_compiler", "to": "consistency_validator" },
    { "from": "consistency_validator", "to": "supervisor" },
    { "from": "semantic_repairer", "to": "supervisor" },
    { "from": "target_renderer", "to": "supervisor" },
    { "from": "supervisor", "to": "END", "condition": { "path": "nodes.supervisor.next_node", "operator": "equals", "value": "END" } }
  ]
}
